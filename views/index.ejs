<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" /> 
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />
  <link rel="stylesheet" href="../static/styles/main.css" />
  <title>Taskify</title>

  <style>
    #cookie-banner {
      position: fixed !important;
      bottom: 0 !important;
      left: 0 !important;
      width: 100% !important;
      background-color: #2d2d2d !important;
      color: #ffffff !important;
      padding: 16px 24px !important;
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      justify-content: space-between !important;
      align-items: center !important;
      z-index: 9999 !important;
      box-sizing: border-box !important;
    }
    #cookie-text {
      font-size: 14px;
      white-space: nowrap;
    }
    #cookie-text a {
      color: #9900f8;
      text-decoration: underline;
      display: inline !important;
    }
    #cookie-buttons {
      display: flex;
      flex-direction: row;
      gap: 12px;
      margin-left: 24px;
      flex-shrink: 0;
    }
    #accept-btn {
      background-color: #9900f8;
      color: white;
      border: none;
      padding: 8px 20px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
    }
    #decline-btn {
      background-color: transparent;
      color: white;
      border: 1px solid white;
      padding: 8px 20px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
    }
  </style>
</head>

<body>
  <%-include("../views/partials/nav.ejs") %>
  <%-include("../views/partials/hero.ejs") %>
  <%-include("../views/partials/feature.ejs") %>
  <%-include("../views/partials/achievements.ejs") %>
  <%-include("../views/partials/footer.ejs") %>

<div id="cookie-banner">
  <span id="cookie-text">
    🍪 <span id="cookie-msg"></span> <a href="/privacy" id="cookie-policy-link" style="color:#9900f8;text-decoration:underline;display:inline !important;"></a>.
  </span>
  <div id="cookie-buttons">
    <button id="accept-btn"></button>
    <button id="decline-btn"></button>
  </div>
</div>

<script>
  // 读取语言
  var lang = localStorage.getItem('lang') || 'en';
  var cookieTranslations = {
    en: {
      msg: 'We use cookies to improve your experience. By using Taskify, you agree to our',
      policy: 'Privacy Policy',
      accept: 'Accept',
      decline: 'Decline'
    },
    zh: {
      msg: '我们使用Cookie来改善您的体验。使用 Taskify 即表示您同意我们的',
      policy: '隐私政策',
      accept: '接受',
      decline: '拒绝'
    }
  };

  function updateCookieBanner() {
    var t = cookieTranslations[lang];
    document.getElementById('cookie-msg').textContent = t.msg;
    document.getElementById('cookie-policy-link').textContent = t.policy;
    document.getElementById('accept-btn').textContent = t.accept;
    document.getElementById('decline-btn').textContent = t.decline;
  }

  updateCookieBanner();

  if (localStorage.getItem('cookieConsent')) {
    document.getElementById('cookie-banner').style.display = 'none';
  }

  document.getElementById('accept-btn').onclick = function() {
    localStorage.setItem('cookieConsent', 'accepted');
    document.getElementById('cookie-banner').style.display = 'none';
  };
  document.getElementById('decline-btn').onclick = function() {
    localStorage.setItem('cookieConsent', 'declined');
    document.getElementById('cookie-banner').style.display = 'none';
  };
</script>
</body>

</html>